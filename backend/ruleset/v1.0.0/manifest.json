{
  "ruleset_version": "v1.0.0",

  "description": "AXIOMS Scoring Ruleset — Version 1.0.0. Defines factor weights, engine ordering, and config file locations.",

  "factors": [
    {
      "name": "Payment History",
      "engine": "paymentHistory",
      "weight_percent": 35,
      "config": "decay.json"
    },
    {
      "name": "Utilization",
      "engine": "utilization",
      "weight_percent": 30,
      "config": "utilization.json"
    },
    {
      "name": "History Length",
      "engine": "historyLength",
      "weight_percent": 15,
      "config": "history_length.json"
    },
    {
      "name": "Credit Mix",
      "engine": "creditMix",
      "weight_percent": 10,
      "config": "credit_mix.json"
    },
    {
      "name": "Penalty",
      "engine": "penalty",
      "weight_percent": 10,
      "config": "penalty.json"
    }
  ],

  "config_files": {
    "decay": "decay.json",
    "utilization": "utilization.json",
    "history_length": "history_length.json",
    "credit_mix": "credit_mix.json",
    "penalty": "penalty.json"
  }
}
